	(gr_text "USB3 and 2\nare 90ohm \ndiff pair"
		(at 77.68 78.63 0)
		(layer "Cmts.User")
		(uuid "53028b5a-ad8c-4522-afd0-a41c05f6d6c6")
		(effects
			(font
				(size 1.2 1.2)
				(thickness 0.19)
			)
			(justify left bottom)
		)
	)
	(gr_text "{dblquote}(1) Driver Type B\nType B driver is the default drive strength, targeted for a fixed impedance distributed system with 50\nohm transmission line, at all available frequencies. Therefore, it is defined as 50 ohm nominal driver.\nThis driver can support total CL of about 15pF for UHS104 card and about 30pF for UHS50 card.\nDrive strength B is the reference driver for definitions of all the rest of the drive strengths.{dblquote}\n\nLine capacitance should be less than ~5pF\nassuming a maximum trace length of 30mm.\n5pF/30mm = 5/3*10^-9 F/m\n\nLine inductance should be less than ~16nH\nassuming a maximum trace length of 30mm.\n16nH/30mm = 5.333*10^-7 H/m\n\nThe spec says T(IH)=0.80ns.\nSo I'll use a maximum line skew of +/-0.5ns.\n\nAssuming E(r) is ~4.5 out propogation delay is\nT(pd)=sqrt(E(r))/c = sqrt(~4.5)/3*10^8=7*10^-9s/m\n0.5ns/7*10^-9s/m= 71.4mm\n"
		(at 144 81 0)
		(layer "User.2")
		(uuid "436057a1-bc03-4ad5-a1ac-332178f27838")
		(effects
			(font
				(size 1 1)
				(thickness 0.15)
			)
			(justify left)
		)
	)
